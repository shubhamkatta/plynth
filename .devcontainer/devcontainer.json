{
  "name": "Plynth dev",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8000, 5432, 6379, 5173],
  "portsAttributes": {
    "8000":  { "label": "Plynth API",      "onAutoForward": "notify"  },
    "5432":  { "label": "Postgres",        "onAutoForward": "silent"  },
    "6379":  { "label": "Redis",           "onAutoForward": "silent"  },
    "5173":  { "label": "Electron Vite",   "onAutoForward": "silent"  }
  },
  "postCreateCommand": "pip install -e '.[dev]' && cp -n .env.example .env && cd apps/admin-electron && npm ci || true",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "github.vscode-pull-request-github"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "[python]": { "editor.defaultFormatter": "charliermarsh.ruff" }
      }
    }
  }
}
