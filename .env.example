# Environment
APP_ENV=development
APP_NAME=product-platform
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Security — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
PASSWORD_MIN_LENGTH=12

# Database
DATABASE_URL=postgresql+asyncpg://platform:platform@db:5432/platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0

# Billing
BILLING_PROVIDER=stripe
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Tenancy
DEFAULT_TRIAL_DAYS=14
GRACE_PERIOD_DAYS=7

# Rate limiting (requests / minute, per IP)
RATE_LIMIT_PER_MINUTE=120

# Platform admin token — required to call /api/v1/admin/products (create / list).
# Generate with: openssl rand -hex 32
PLATFORM_ADMIN_TOKEN=change-me-platform-admin-token
