# Caddy config for production deploys behind Cloudflare. Replace
# `api.example.com` below with your own hostname.
#
# Copy to `Caddyfile` (no extension) on the server, edit the hostname,
# then bring the stack up.
#
# Setup model: Cloudflare proxies traffic (orange cloud) and terminates
# TLS to the browser using its own browser-trusted cert. To the origin,
# Cloudflare presents a connection authenticated by a Cloudflare Origin
# Certificate — a free, 15-year, never-renewing cert that's only trusted
# by Cloudflare. That cert lives at `./certs/origin.pem` + `origin.key`
# on the host (mounted into the container at `/etc/caddy/certs/`).
#
# If you'd rather skip Cloudflare's proxy and have Caddy provision its
# own Let's Encrypt cert automatically, delete the `tls ...` line below
# (Caddy auto-issues with no extra config) and flip the Cloudflare CNAME
# back to "DNS only" (grey cloud).

api.example.com {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

    reverse_proxy api:8000

    encode gzip zstd

    log {
        output stdout
        format json
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }
}
