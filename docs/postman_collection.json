{
  "info": {
    "name": "Product Platform API",
    "description": "Reusable multi-product / multi-tenant SaaS platform API. Set `baseUrl`, `productSlug`, and `platformAdminToken` in the collection variables (or environment) before running. Auth flow: run **Admin → Create Product** (once) → **Auth → Register** or **Auth → Login** — the test scripts auto-populate `accessToken` + `refreshToken`. For parent → child workflows, run **Tenants → List Children** to populate `actingTenantSlug`, then any request that adds `X-Acting-Tenant-Slug: {{actingTenantSlug}}` scopes to the child.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "8c0c2a90-platform-scaffold-001"
  },
  "variable": [
    { "key": "baseUrl",             "value": "http://localhost:8000", "type": "string" },
    { "key": "productSlug",         "value": "platform",              "type": "string" },
    { "key": "platformAdminToken",  "value": "change-me-platform-admin-token", "type": "string" },
    { "key": "accessToken",         "value": "",                      "type": "string" },
    { "key": "refreshToken",        "value": "",                      "type": "string" },
    { "key": "tenantId",            "value": "",                      "type": "string" },
    { "key": "userId",              "value": "",                      "type": "string" },
    { "key": "roleId",              "value": "",                      "type": "string" },
    { "key": "actingTenantSlug",    "value": "",                      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Meta",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [],
            "url": { "raw": "{{baseUrl}}/ready", "host": ["{{baseUrl}}"], "path": ["ready"] }
          }
        }
      ]
    },
    {
      "name": "Admin (Platform)",
      "description": "Platform-admin endpoints. Authenticated via `X-Platform-Admin-Token` only — no product context required. These sit *above* products.",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Platform-Admin-Token", "value": "{{platformAdminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/products",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products"]
            }
          }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.slug) pm.collectionVariables.set('productSlug', json.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Platform-Admin-Token", "value": "{{platformAdminToken}}" },
              { "key": "Content-Type",           "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Product\",\n  \"slug\": \"my-product\",\n  \"description\": \"Brand new product\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/products",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Public auth flows. Each request below sends `X-Product-Slug` (required for register / login). Authenticated routes also send the bearer token via the collection-level auth.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('accessToken',  json.access_token);",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_name\": \"Acme Inc\",\n  \"tenant_slug\": \"acme\",\n  \"email\": \"owner@acme.example.com\",\n  \"password\": \"S3cretPassword!\",\n  \"full_name\": \"Alice Owner\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('accessToken',  json.access_token);",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@acme.example.com\",\n  \"password\": \"S3cretPassword!\",\n  \"tenant_slug\": \"acme\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('accessToken',  json.access_token);",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout (this session)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\",\n  \"all_sessions\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"]
            }
          }
        },
        {
          "name": "Logout (all sessions)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"all_sessions\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"S3cretPassword!\",\n  \"new_password\": \"BrandNewPwd99!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/password",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "password"]
            }
          }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id)        pm.collectionVariables.set('userId',   json.id);",
                  "if (json.tenant_id) pm.collectionVariables.set('tenantId', json.tenant_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "List Tenants",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "tenants"]
            }
          }
        },
        {
          "name": "List Children (Act-As picker)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const rows = pm.response.json();",
                  "const first = rows.find(r => r.can_act_as);",
                  "if (first) pm.collectionVariables.set('actingTenantSlug', first.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants/children",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "tenants", "children"]
            },
            "description": "Lists direct children of the caller's home tenant with a `can_act_as` flag and a `reason` when false. Auto-stores the first switchable child's slug in `actingTenantSlug`."
          }
        },
        {
          "name": "Create Child Tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme East\",\n  \"slug\": \"acme-east\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "tenants"]
            }
          }
        },
        {
          "name": "Update Tenant",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed Tenant\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants/{{tenantId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "tenants", "{{tenantId}}"]
            }
          }
        },
        {
          "name": "Deactivate Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants/{{tenantId}}/deactivate",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "tenants", "{{tenantId}}", "deactivate"]
            }
          }
        },
        {
          "name": "Activate Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants/{{tenantId}}/activate",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "tenants", "{{tenantId}}", "activate"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"]
            }
          }
        },
        {
          "name": "List Users (Acting as child)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Product-Slug",        "value": "{{productSlug}}" },
              { "key": "X-Acting-Tenant-Slug",  "value": "{{actingTenantSlug}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"]
            },
            "description": "Identical to **List Users** but the request is scoped to the child tenant `{{actingTenantSlug}}`. Set the variable by running **Tenants → List Children** first, or hard-code it. Every endpoint accepts this header — copy the pattern wherever you need parent → child access."
          }
        },
        {
          "name": "Invite User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('userId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new@acme.example.com\",\n  \"full_name\": \"New User\",\n  \"role_codes\": [\"member\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Updated Name\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Activate User",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/activate",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}", "activate"]
            }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/deactivate",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}", "deactivate"]
            }
          }
        },
        {
          "name": "Delete User (soft)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/roles",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles"]
            }
          }
        },
        {
          "name": "List Permissions Catalog",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/roles/permissions",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles", "permissions"]
            }
          }
        },
        {
          "name": "Create Custom Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('roleId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"auditor\",\n  \"description\": \"Read-only audit access\",\n  \"permission_codes\": [\"users:read\", \"audit:read\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/roles",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles"]
            }
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\",\n  \"permission_codes\": [\"users:read\", \"audit:read\", \"credits:read\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/roles/{{roleId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles", "{{roleId}}"]
            }
          }
        },
        {
          "name": "Assign Role to User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"role_id\": \"{{roleId}}\",\n  \"scope_tenant_id\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/roles/assign",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles", "assign"]
            }
          }
        }
      ]
    },
    {
      "name": "Plans",
      "item": [
        {
          "name": "List Public Plans",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/plans",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "plans"]
            }
          }
        },
        {
          "name": "Create Plan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
