            "header": [
              { "key": "X-Product-Slug", "value": "{{productSlug}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Team (renamed)\",\n  \"price_cents\": 5900\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/plans/team",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "plans", "team"]
            }
          }
        }
      ]
    },
    {
      "name": "Subscription",
      "item": [
        {
          "name": "Get Subscription",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Product-Slug", "value": "{{productSlug}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscription",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "subscription"]
            }
          }
        },
        {
          "name": "Purchase Plan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug",   "value": "{{productSlug}}" },
              { "key": "Idempotency-Key",  "value": "{{$guid}}" },
              { "key": "Content-Type",     "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_code\": \"pro\",\n  \"payment_method_token\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscription/purchase",
              "host": ["{{baseUrl}}"], "path": ["api", "v1", "subscription", "purchase"]
            }
          }
        },
        {
          "name": "Change Plan (upgrade / downgrade)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Product-Slug",   "value": "{{productSlug}}" },
              { "key": "Idempotency-Key",  "value": "{{$guid}}" },
              { "key": "Content-Type",     "value": "application/json" }
