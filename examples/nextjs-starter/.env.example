# Plynth platform base URL (server-side fetches use this).
PLYNTH_API_URL=http://localhost:8000

# Your product slug as registered on the platform. Public — sent as
# X-Product-Slug on every request. Exposed to the browser via NEXT_PUBLIC_.
NEXT_PUBLIC_PLYNTH_PRODUCT_SLUG=demo

# Same slug — duplicated as a server-only env so server code does not need
# the NEXT_PUBLIC_ prefix. Keep both in sync.
PLYNTH_PRODUCT_SLUG=demo
