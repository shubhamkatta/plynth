{
  "name": "@plynth/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Plynth platform — auth, tenants, plans, credits, RBAC.",
  "license": "MIT",
  "author": "Shubham Katta <shubhamkatta7@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shubhamkatta/plynth.git",
    "directory": "sdks/typescript"
  },
  "homepage": "https://shubhamkatta.github.io/plynth/",
  "bugs": "https://github.com/shubhamkatta/plynth/issues",
  "keywords": ["plynth", "saas", "multi-tenant", "rbac", "billing", "sdk"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
